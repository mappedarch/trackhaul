# Copy this file to terraform.tfvars and fill in real values
# Never commit terraform.tfvars

aws_region     = "eu-central-1"
aws_region_dr  = "eu-west-1"

management_account_id  = "REPLACE_WITH_MANAGEMENT_ACCOUNT_ID"
security_account_id    = "REPLACE_WITH_SECURITY_ACCOUNT_ID"
log_archive_account_id = "REPLACE_WITH_LOG_ARCHIVE_ACCOUNT_ID"
dev_account_id         = "REPLACE_WITH_DEV_ACCOUNT_ID"
prod_account_id        = "REPLACE_WITH_PROD_ACCOUNT_ID"

org_id = "REPLACE_WITH_ORG_ID"

management_email  = "REPLACE_WITH_MANAGEMENT_EMAIL"
security_email    = "REPLACE_WITH_SECURITY_EMAIL"
log_archive_email = "REPLACE_WITH_LOG_ARCHIVE_EMAIL"
dev_email         = "REPLACE_WITH_DEV_EMAIL"
prod_email        = "REPLACE_WITH_PROD_EMAIL"